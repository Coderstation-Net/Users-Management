    <!-- 2FA Setup Modal -->
    <div class="modal" id="setup2FAModal">
        <div class="modal-dialog">
            <div class="modal-header">
                <h3 class="modal-title" style="margin: 0;">Setup Google Authenticator</h3>
                <button class="modal-close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <p class="text-center mb-3">Scan this QR code with your Google Authenticator app:</p>
                <div class="qr-code-container text-center mb-3" id="qrCodeContainer">
                    <!-- QR Code will be generated here -->
                </div>
                <div class="form-group-floating">
                    <input type="text" class="form-control" id="secretKey" readonly placeholder=" ">
                    <label for="secretKey">Secret Key (Manual Entry)</label>
                    <button type="button" class="btn btn-sm btn-secondary mt-1"
                        style="position: absolute; right: 10px; top: 10px; z-index: 5;"
                        onclick="Utils.copyToClipboard($('#secretKey').val())">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <div class="form-group-floating">
                    <input type="text" class="form-control" id="verifyCode" maxlength="6" placeholder=" ">
                    <label for="verifyCode">Enter 6-digit code</label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="enable2FABtn">Enable 2FA</button>
            </div>
        </div>
    </div>

    <!-- 2FA Disable Modal -->
    <div class="modal" id="disable2FAModal">
        <div class="modal-dialog">
            <div class="modal-header">
                <h3 class="modal-title" style="margin: 0;">Disable 2FA</h3>
                <button class="modal-close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <p>Enter your password to disable 2FA:</p>
                <div class="form-group-floating">
                    <input type="password" class="form-control" id="disable2FAPassword" placeholder=" ">
                    <label for="disable2FAPassword">Password</label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button class="btn btn-danger" id="confirm-disable2FABtn">Disable 2FA</button>
            </div>
        </div>
    </div>

    <!-- Confirm Unlink Gmail Modal -->
    <div class="modal" id="userUnlinkGmailModal">
        <div class="modal-dialog" style="max-width: 400px;">
            <div class="modal-header">
                <h3 class="modal-title" style="margin: 0;"><i class="fab fa-google text-danger"></i> Unlink Google Account</h3>
                <button class="modal-close" id="closeUserUnlinkGmail">&times;</button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to <strong>unlink your Google account</strong>? You will no longer be able to sign in using Google OAuth.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" id="cancelUserUnlinkGmail">Cancel</button>
                <button class="btn btn-danger" id="confirmUserUnlinkGmail"><i class="fas fa-unlink"></i> Yes, Unlink</button>
            </div>
        </div>
    </div>

